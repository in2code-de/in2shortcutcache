{
    "name": "in2code/in2shortcutcache",
    "description": "Fixes cache lifetime for pages with shortcut (Insert Records) content elements in TYPO3",
    "type": "typo3-cms-extension",
    "homepage": "https://www.in2code.de",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Sandra Pohl",
            "email": "sandra.pohl@in2code.de",
            "homepage": "https://www.in2code.de",
            "role": "Product owner"
        },
        {
            "name": "Alexander Kellner",
            "email": "alexander.kellner@in2code.de",
            "role": "Developer",
            "homepage": "https://www.in2code.de"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^13.4",
        "typo3/cms-frontend": "^13.4"
    },
    "require-dev": {
        "helhum/typo3-console": "^8.3",
        "typo3/cms-backend": "^13.4",
        "typo3/cms-belog": "^13.4",
        "typo3/cms-beuser": "^13.4",
        "typo3/cms-dashboard": "^13.4",
        "typo3/cms-extbase": "^13.4",
        "typo3/cms-extensionmanager": "^13.4",
        "typo3/cms-filelist": "^13.4",
        "typo3/cms-fluid": "^13.4",
        "typo3/cms-fluid-styled-content": "^13.4",
        "typo3/cms-info": "^13.4",
        "typo3/cms-install": "^13.4",
        "typo3/cms-lowlevel": "^13.4",
        "typo3/cms-rte-ckeditor": "^13.4",
        "typo3/cms-scheduler": "^13.4",
        "typo3/cms-setup": "^13.4",
        "typo3/cms-tstemplate": "^13.4"
    },
    "suggest": {
        "in2code/in2frequently": "^2.0 - Enables cache lifetime reduction for in2frequently recurring visibility fields on shortcut-referenced content elements"
    },
    "autoload": {
        "psr-4": {
            "In2code\\In2shortcutcache\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "cms-package-dir": "{$vendor-dir}/typo3/cms",
            "web-dir": ".Build/public",
            "extension-key": "in2shortcutcache"
        }
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "sort-packages": true,
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    }
}
